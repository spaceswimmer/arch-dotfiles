#!/usr/bin/env bash

repo_root=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

validate_relative_path() {
  local path=$1 part
  [[ -n $path && $path != /* ]] || die "allowlist path must be relative: $path"
  [[ $path != *$'\n'* && $path != *$'\r'* ]] || die 'allowlist path contains a newline'
  IFS='/' read -r -a parts <<< "$path"
  for part in "${parts[@]}"; do
    [[ -n $part && $part != . && $part != .. ]] || die "unsafe allowlist path: $path"
  done
}

assert_not_denied() {
  local path=$1 name
  name=${path##*/}
  case "/$path/" in
    */.git/*|*/.ssh/*|*/.gnupg/*|*/.aws/*|*/.kube/*|*/.password-store/*|*/.local/share/keyrings/*|*/.local/share/kwalletd/*|*/.local/share/opencode/*|*/.config/rclone/*|*/.config/wayvnc/*|*/.config/remmina/*|*/.config/freerdp/*|*/.config/Nextcloud/*|*/.config/google-chrome/*|*/.config/chromium/*|*/.config/mozilla/*|*/.config/discord/*|*/.config/pulse/*)
      die "sensitive path is always denied: $path"
      ;;
  esac
  case "$name" in
    .env|.env.*|*.key|*.pem|*.p12|*.pfx|*history*|*cookie*|connections.db|credentials|credentials.*|secrets|secrets.*|id_rsa|id_ed25519)
      die "sensitive filename is always denied: $path"
      ;;
  esac
}

load_allowlist() {
  local line existing
  ALLOWLIST=()
  [[ -f $repo_root/manifests/allowlist.txt ]] || die 'missing manifests/allowlist.txt'
  while IFS= read -r line || [[ -n $line ]]; do
    line=${line%$'\r'}
    [[ -z $line || $line == \#* ]] && continue
    validate_relative_path "$line"
    assert_not_denied "$line"
    for existing in "${ALLOWLIST[@]}"; do
      [[ $line != "$existing" && $line != "$existing"/* && $existing != "$line"/* ]] || die "duplicate or overlapping allowlist paths: $existing and $line"
    done
    ALLOWLIST+=("$line")
  done < "$repo_root/manifests/allowlist.txt"
  ((${#ALLOWLIST[@]} > 0)) || die 'allowlist is empty'
}

assert_source_safe() {
  local source=$1 resolved
  [[ -e $source || -L $source ]] || return 0
  resolved=$(realpath -m -- "$source")
  case "$resolved" in
    "$HOME"|"$HOME"/*) ;;
    *) die "source resolves outside HOME: ${source#"$HOME"/}" ;;
  esac
  [[ ! -S $source && ! -p $source && ! -b $source && ! -c $source ]] || die "unsupported special file: ${source#"$HOME"/}"
}

validate_tree() {
  local root=$1 boundary=$2 item relative resolved allowed
  local -a items
  [[ -e $root || -L $root ]] || return 0
  mapfile -d '' -t items < <(find -P "$root" -print0)
  for item in "${items[@]}"; do
    relative=${item#"$boundary"/}
    [[ $relative != "$item" ]] || die "tree entry is outside boundary: $item"
    assert_not_denied "$relative"
    if [[ -L $item ]]; then
      resolved=$(realpath -m -- "$item")
      case "$resolved" in
        "$boundary"|"$boundary"/*) ;;
        *) die "symlink resolves outside boundary: $relative" ;;
      esac
    elif [[ ! -f $item && ! -d $item ]]; then
      die "unsupported special file: $relative"
    fi
  done
}

validate_snapshot_coverage() {
  local root=$1 item relative entry covered
  local -a items
  mapfile -d '' -t items < <(find -P "$root" -mindepth 1 -print0)
  for item in "${items[@]}"; do
    relative=${item#"$root"/}
    [[ $relative != "$item" ]] || continue
    covered=false
    for entry in "${ALLOWLIST[@]}"; do
      if [[ $relative == "$entry" || $relative == "$entry"/* || $entry == "$relative"/* ]]; then
        covered=true
        break
      fi
    done
    [[ $covered == true ]] || die "snapshot path is not allowlisted: $relative"
  done
}

secret_pattern="BEGIN ([A-Z0-9 ]+ )?PRIVATE KEY|(^|[^A-Za-z0-9])(gh[pousr]_[A-Za-z0-9]{20,}|github_pat_[A-Za-z0-9_]{20,}|AKIA[0-9A-Z]{16}|xox[baprs]-[A-Za-z0-9-]{10,})|(^|[^A-Za-z0-9_])(api[_-]?key|access[_-]?token|auth[_-]?token|client[_-]?secret|password|passwd)[[:space:]]*[:=][[:space:]]*['\"]?[^[:space:]$'\"]{12,}"

scan_tree() {
  local target=$1 matches status
  [[ -d $target ]] || return 0
  if command -v rg >/dev/null 2>&1; then
    if matches=$(rg -l -i --hidden --no-ignore --glob '!.git/**' -- "$secret_pattern" "$target"); then
      :
    else
      status=$?
      ((status == 1)) || die "secret scanner failed while reading $target"
      matches=
    fi
  else
    if matches=$(grep -Eirl -- "$secret_pattern" "$target" 2>/dev/null); then
      :
    else
      status=$?
      ((status == 1)) || die "secret scanner failed while reading $target"
      matches=
    fi
  fi
  if [[ -n $matches ]]; then
    printf 'error: possible secret material detected in:\n' >&2
    while IFS= read -r file; do printf '  %s\n' "${file#"$repo_root"/}" >&2; done <<< "$matches"
    return 1
  fi
}

scan_history() {
  local history status
  [[ -d $repo_root/.git ]] || return 0
  git -C "$repo_root" rev-parse --verify HEAD >/dev/null 2>&1 || return 0
  history=$(mktemp)
  git -C "$repo_root" log --all --format=fuller --patch --binary > "$history"
  if command -v rg >/dev/null 2>&1; then
    if rg -q -i -- "$secret_pattern" "$history"; then status=0; else status=$?; fi
  else
    if grep -Eiq -- "$secret_pattern" "$history"; then status=0; else status=$?; fi
  fi
  if ((status == 0)); then
    rm -f "$history"
    die 'possible secret material detected in Git history'
  fi
  if ((status != 1)); then
    rm -f "$history"
    die 'secret scanner failed while reading Git history'
  fi
  rm -f "$history"
}

sanitize_snapshot() {
  local root=$1 file
  local -a images
  local files=(
    .zshrc
    .zshenv
    .config/hypr/hyprland.conf
    .config/hypr/hyprpaper.conf
    .config/swaync/config.json
    .config/waybar/modules.jsonc
    .config/waybar/scripts/launch.sh
  )
  for file in "${files[@]}"; do
    [[ -f $root/$file ]] || continue
    HOME_TO_REPLACE=$HOME perl -pi -e 's{\Q$ENV{HOME_TO_REPLACE}\E}{\$HOME}g' "$root/$file"
  done
  if [[ -f $root/.config/waybar/modules.jsonc ]]; then
    perl -pi -e 's{"\$HOME/\.config/waybar/context/}{"~/.config/waybar/context/}g' "$root/.config/waybar/modules.jsonc"
  fi
  if [[ -f $root/.config/hypr/hyprland.conf ]]; then
    perl -ni -e 'print unless /Start wayvnc|graphical-session\.target|systemctl --user start wayvnc/' "$root/.config/hypr/hyprland.conf"
  fi
  if command -v magick >/dev/null 2>&1; then
    mapfile -d '' -t images < <(find -P "$root" -type f \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' \) -print0)
    ((${#images[@]} == 0)) || magick mogrify -strip "${images[@]}"
  fi
}
