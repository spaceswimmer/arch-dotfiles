#!/usr/bin/env bash
set -euo pipefail

repo=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)
tmp=$(mktemp -d)
trap 'rm -rf "$tmp"' EXIT

fail() {
  printf 'FAIL: %s\n' "$1" >&2
  exit 1
}

assert_fails() {
  if "$@" >/dev/null 2>&1; then
    fail "command unexpectedly succeeded: $*"
  fi
}

fixture="$tmp/repo"
cp -a "$repo/." "$fixture"
rm -rf "$fixture/.git" "$fixture/home"
mkdir -p "$fixture/home" "$tmp/home/.config/app"
printf 'setting=true\n' > "$tmp/home/.config/app/config"
printf '.config/app/config\n' > "$fixture/manifests/allowlist.txt"

HOME="$tmp/home" "$fixture/bin/sync" >/dev/null
[[ ! -e "$fixture/home/.config/app/config" ]] || fail 'sync dry-run changed repository'
HOME="$tmp/home" "$fixture/bin/sync" --apply >/dev/null
cmp "$tmp/home/.config/app/config" "$fixture/home/.config/app/config" >/dev/null || fail 'sync did not copy allowlisted file'

printf 'snapshot-before-failure=true\n' > "$fixture/home/.config/app/config"
printf 'live-after-failure=true\n' > "$tmp/home/.config/app/config"
mkdir -p "$tmp/fake-bin"
real_mv=$(command -v mv)
printf '#!/usr/bin/env bash\nargs=("$@")\n[[ $1 == -- ]] && shift\nif [[ $1 == */.sync-*/home && $2 == */home ]]; then exit 2; fi\nexec %q "${args[@]}"\n' "$real_mv" > "$tmp/fake-bin/mv"
chmod +x "$tmp/fake-bin/mv"
assert_fails env HOME="$tmp/home" PATH="$tmp/fake-bin:$PATH" "$fixture/bin/sync" --apply
grep -q 'snapshot-before-failure=true' "$fixture/home/.config/app/config" || fail 'failed sync did not restore previous snapshot'
printf 'setting=true\n' > "$tmp/home/.config/app/config"
printf 'setting=true\n' > "$fixture/home/.config/app/config"

printf '../outside\n' > "$fixture/manifests/allowlist.txt"
assert_fails env HOME="$tmp/home" "$fixture/bin/sync" --apply

printf '.ssh/config\n' > "$fixture/manifests/allowlist.txt"
mkdir -p "$tmp/home/.ssh"
printf 'Host private\n' > "$tmp/home/.ssh/config"
assert_fails env HOME="$tmp/home" "$fixture/bin/sync" --apply

printf '.config/app/config\n' > "$fixture/manifests/allowlist.txt"
printf 'token = ghp_%s\n' 'abcdefghijklmnopqrstuvwxyz123456' > "$fixture/home/.config/app/config"
assert_fails "$fixture/bin/verify"

printf 'setting=true\n' > "$fixture/home/.config/app/config"
printf '.config/app\n' > "$fixture/manifests/allowlist.txt"
printf 'token = ghp_%s\n' 'abcdefghijklmnopqrstuvwxyz123456' > "$fixture/home/.config/app/settings.example"
assert_fails "$fixture/bin/verify"
rm "$fixture/home/.config/app/settings.example"

printf 'token = ghp_%s\n' 'abcdefghijklmnopqrstuvwxyz123456' > "$fixture/home/.config/app/danger.log"
assert_fails "$fixture/bin/verify"
rm "$fixture/home/.config/app/danger.log"

git -C "$fixture" init -q
git -C "$fixture" add home/.config/app/config
printf 'token = ghp_%s\n' 'abcdefghijklmnopqrstuvwxyz123456' > "$fixture/home/.config/app/config"
git -C "$fixture" add home/.config/app/config
env GIT_AUTHOR_NAME=Test GIT_AUTHOR_EMAIL=test@example.invalid GIT_COMMITTER_NAME=Test GIT_COMMITTER_EMAIL=test@example.invalid git -C "$fixture" commit -qm 'add synthetic secret'
printf 'setting=true\n' > "$fixture/home/.config/app/config"
git -C "$fixture" add home/.config/app/config
env GIT_AUTHOR_NAME=Test GIT_AUTHOR_EMAIL=test@example.invalid GIT_COMMITTER_NAME=Test GIT_COMMITTER_EMAIL=test@example.invalid git -C "$fixture" commit -qm 'remove synthetic secret'
assert_fails "$fixture/bin/verify"
rm -rf "$fixture/.git"

git -C "$fixture" init -q
printf '*.log\n' > "$fixture/.gitignore"
git -C "$fixture" add .gitignore home/.config/app/config
env GIT_AUTHOR_NAME=Test GIT_AUTHOR_EMAIL=test@example.invalid GIT_COMMITTER_NAME=Test GIT_COMMITTER_EMAIL=test@example.invalid git -C "$fixture" commit -qm 'safe baseline'
assert_fails bash -c 'source "$1/bin/lib"; rg() { return 2; }; scan_history' _ "$fixture"
printf 'token = ghp_%s\n' 'abcdefghijklmnopqrstuvwxyz123456' > "$fixture/home/.config/app/staged.log"
git -C "$fixture" add -f home/.config/app/staged.log
rm "$fixture/home/.config/app/staged.log"
assert_fails "$fixture/bin/verify"
rm -rf "$fixture/.git"

ln -s "$tmp/outside" "$tmp/home/.config/app/escape"
assert_fails env HOME="$tmp/home" "$fixture/bin/sync" --apply
rm "$tmp/home/.config/app/escape"

mkdir -p "$fixture/home/.config/extra"
printf 'extra=true\n' > "$fixture/home/.config/extra/config"
assert_fails "$fixture/bin/verify"
rm -rf "$fixture/home/.config/extra"

printf 'restored=true\n' > "$fixture/home/.config/app/config"
printf 'local=true\n' > "$tmp/home/.config/app/config"
HOME="$tmp/home" XDG_STATE_HOME="$tmp/state" "$fixture/bin/restore" >/dev/null
grep -q 'local=true' "$tmp/home/.config/app/config" || fail 'restore dry-run changed HOME'
HOME="$tmp/home" XDG_STATE_HOME="$tmp/state" "$fixture/bin/restore" --apply >/dev/null
grep -q 'restored=true' "$tmp/home/.config/app/config" || fail 'restore did not install snapshot'
grep -Rqs 'local=true' "$tmp/state/arch-dotfiles/backups" || fail 'restore did not back up conflict'

printf 'second-local=true\n' > "$tmp/home/.config/app/config"
HOME="$tmp/home" XDG_STATE_HOME="$tmp/state" "$fixture/bin/restore" --apply >/dev/null
grep -Rqs 'second-local=true' "$tmp/state/arch-dotfiles/backups" || fail 'repeated restore overwrote its backup'
grep -Rqs 'local=true' "$tmp/state/arch-dotfiles/backups" || fail 'repeated restore lost the first backup'

printf 'PASS: dotfile safety tests\n'
