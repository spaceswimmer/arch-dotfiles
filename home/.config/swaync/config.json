{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "cssPriority": "user",

  "control-center-width": 380,
  "control-center-height": 860,
  "control-center-margin-top": 2,
  "control-center-margin-bottom": 2,
  "control-center-margin-right": 1,
  "control-center-margin-left": 0,

  "notification-window-width": 400,
  "notification-icon-size": 72,
  "notification-body-image-height": 160,
  "notification-body-image-width": 200,

  "timeout": 4,
  "timeout-low": 2,
  "timeout-critical": 6,

  "fit-to-screen": false,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": false,
  "script-fail-notify": true,
  "scripts": {
    "example-script": {
      "exec": "echo 'Do something...'",
      "urgency": "Normal"
    }
  },
  "notification-visibility": {
    "example-name": {
      "state": "muted",
      "urgency": "Low",
      "app-name": "Spotify"
    }
  },
  "widgets": [
    "title",
    "dnd",
    "backlight",
    "buttons-grid",
    "mpris",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": " 󰎟 "
    },
    "dnd": {
      "text": "Do not disturb"
    },
    "backlight": {
      "label": "󰃠",
      "device": "intel_backlight",
      "min": 5
    },
    "mpris": {
      "image-size": 96,
      "image-radius": 12,
      "blacklist": [ "org.mpris.MediaPlayer2.playerctld" ]
    },
    "buttons-grid": {
      "actions": [
        {
          "label": "󰋋",
          "command": "bash -c 'if pgrep -x pavucontrol; then pkill pavucontrol; else /usr/sbin/pavucontrol & fi'"
        },
        {
          "label": "󰍬",
          "type": "toggle",
          "command": "bash -c 'pactl set-source-mute @DEFAULT_SOURCE@ toggle'",
          "update-command": "bash $HOME/.config/swaync/scripts/mic_status.sh"
        },
        {
          "label": "󱘖",
          "command": "/usr/sbin/nm-connection-editor"
        },

        {
          "label": "⏻",
          "command": "/usr/sbin/wlogout"
        }
      ]
    }
  }
}
